#!/usr/bin/env bash
# Launch SalvageMap with root privileges (needed to read raw block devices).
# When run as a normal user this re-execs itself through pkexec, which pops the
# graphical polkit password prompt. pkexec scrubs the environment, so we forward
# the display bits explicitly and prefer the native Wayland platform (falling
# back to XWayland/xcb) so the elevated app looks identical to a normal launch.
#
# Prefer NOT running the whole GUI as root: adding yourself to the `disk` group
# (`sudo usermod -aG disk $USER`, then log out/in) lets `salvagemap` read devices
# without any of this.

if [ "${EUID:-$(id -u)}" -ne 0 ]; then
    # Authorise root to talk to the (X)Wayland display, remembering whether we
    # actually granted it so we can revoke exactly that afterwards.
    granted=0
    if command -v xhost >/dev/null 2>&1; then
        if xhost +SI:localuser:root >/dev/null 2>&1; then
            granted=1
        fi
    fi

    pkexec env \
        DISPLAY="${DISPLAY:-:0}" \
        XAUTHORITY="${XAUTHORITY:-}" \
        WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-}" \
        XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-}" \
        XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-}" \
        DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-}" \
        QT_QPA_PLATFORM="wayland;xcb" \
        PYTHONPATH="/usr/lib/salvagemap" \
        python3 -m app.main "$@"
    status=$?

    if [ "$granted" -eq 1 ]; then
        xhost -SI:localuser:root >/dev/null 2>&1 || true
    fi
    exit "$status"
fi

# Already running as root.
export PYTHONPATH="/usr/lib/salvagemap${PYTHONPATH:+:$PYTHONPATH}"
exec python3 -m app.main "$@"
